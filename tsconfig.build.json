{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "composite": false,
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true
  },
  "include": ["src/index.ts", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx", "e2e"]
}
